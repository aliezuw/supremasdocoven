			allAbilityKeys = {},
			abilityDisplayByKey = {},
			abilityKeyByDisplay = {},
			allAbilityDisplayOptions = {},
		}
		local outspammerSelections = {
			selectedAbilityByKey = {},
			selectedOffenseByKey = {},
			selectedAbilities = {},
			offenseAbilities = {},
		}
