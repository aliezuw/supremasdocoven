				espView.Color3ToHex = function(color)
					local r = math.floor(color.R * 255)
					local g = math.floor(color.G * 255)
					local b = math.floor(color.B * 255)
					return string.format("#%02X%02X%02X", r, g, b)
				end

				local renderConn = RunService.RenderStepped:Connect(function(deltaTime)
					if not espState.enabled then
						for _, espData in pairs(espState.esp) do
							espView.hideBasePlayerESP(espData)
						end
						for _, espData in pairs(espState.stakeESP) do
