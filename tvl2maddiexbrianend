							if char and char:IsDescendantOf(workspace) then
								local hrp = char:FindFirstChild("HumanoidRootPart")
								local hum = char:FindFirstChildOfClass("Humanoid")

								if hrp and hum and hum.Health > 0 and not espView.isCharacterInLobby(char) then
									local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
									if onScreen and espState.enabled then
										if not espState.esp[targetPlayer] then
											espState.esp[targetPlayer] = {
												charNameText = espView.createTextLabel(
													11,
													Color3.fromRGB(150, 150, 150)
												),
												userNameText = espView.createTextLabel(
													11,
													Color3.fromRGB(255, 255, 255)
												),
												distanceText = espView.createTextLabel(
													10,
													Color3.fromRGB(200, 200, 200)
												),
												toolText = espView.createTextLabel(9, Color3.fromRGB(150, 150, 150)),
												targetPosition = Vector2.new(screenPos.X, screenPos.Y),
												currentPosition = Vector2.new(screenPos.X, screenPos.Y),
											}
										end

										local espObj = espState.esp[targetPlayer]

										local targetPos = Vector2.new(screenPos.X, screenPos.Y)
										espObj.targetPosition = targetPos

										local smoothX, smoothY
										if espState.useLerping then
											local lerpFactor = math.min(deltaTime * 15, 1)
											espObj.currentPosition = espObj.currentPosition:Lerp(targetPos, lerpFactor)
											smoothX = espObj.currentPosition.X
											smoothY = espObj.currentPosition.Y
										else
											espObj.currentPosition = targetPos
											smoothX = screenPos.X
											smoothY = screenPos.Y
										end

										if espState.enabled then
											local charName = char:GetAttribute("CharacterName")
												or characterNamesCache[targetPlayer.UserId]
											local specieType = char:GetAttribute("SpecieType")
												or specieTypesCache[targetPlayer.UserId]

											if charName and charName ~= "" then
												espObj.charNameText.RichText = true
												local color = Color3.fromRGB(255, 255, 255)
												if specieType and specieType ~= "" and SpeciesData[specieType] then
													color = SpeciesData[specieType].specieColor
												end

												espObj.charNameText.Text = charName
													.. " <font color='"
													.. espView.Color3ToHex(color)
													.. "'>("
													.. (specieType or "Unknown")
													.. ")</font>"
												espObj.charNameText.Position =
													UDim2.new(0, smoothX - 100, 0, smoothY - 50)

												local textColor = Color3.fromRGB(150, 150, 150)
												local specialColor = specialCharColors[charName]
												if specialColor then
													textColor = specialColor
												end
												espObj.charNameText.TextColor3 = textColor
												espObj.charNameText.Visible = true
											else
												espObj.charNameText.Visible = false
											end

											local displayName = (targetPlayer.DisplayName ~= targetPlayer.Name)
													and (targetPlayer.DisplayName .. " (" .. targetPlayer.Name .. ")")
