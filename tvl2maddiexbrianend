local function getTier(whitelist, userId, hwid)
	local normalizedHwid = tostring(hwid or ""):lower()
	for _, id in ipairs(getWhitelistValuesForTier(whitelist.premium, "users")) do
		if id == userId then
			return "premium"
		end
	end
	for _, savedHwid in ipairs(getWhitelistValuesForTier(whitelist.premium, "hwids")) do
		if tostring(savedHwid):lower() == normalizedHwid and normalizedHwid ~= "" then
			return "premium"
		end
	end
	for _, id in ipairs(getWhitelistValuesForTier(whitelist.normal, "users")) do
		if id == userId then
			return "normal"
		end
	end
	for _, savedHwid in ipairs(getWhitelistValuesForTier(whitelist.normal, "hwids")) do
		if tostring(savedHwid):lower() == normalizedHwid and normalizedHwid ~= "" then
			return "normal"
		end
	end
	return nil
end

