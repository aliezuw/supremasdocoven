-- SETTINGS
do
	local Lighting = game:GetService("Lighting")
	env.tvlFpsBoostState = env.tvlFpsBoostState or {
		connections = {},
	}
	local fpsBoostState = env.tvlFpsBoostState

	local function disconnectBoostFpsConnections()
		for _, connection in ipairs(fpsBoostState.connections) do
			if typeof(connection) == "RBXScriptConnection" then
				connection:Disconnect()
			end
		end
		table.clear(fpsBoostState.connections)
	end

	local function optimizeInstanceForBoostFps(instance)
		if not instance then
			return
		end

		if instance:IsA("BasePart") then
			pcall(function()
				instance.Material = Enum.Material.Plastic
				instance.Reflectance = 0
			end)
		elseif instance:IsA("Explosion") then
			pcall(function()
				instance.BlastPressure = 1
				instance.BlastRadius = 1
			end)
		elseif
			instance:IsA("ForceField")
			or instance:IsA("Sparkles")
			or instance:IsA("Smoke")
			or instance:IsA("Fire")
		then
			task.spawn(function()
				RunService.Heartbeat:Wait()
				pcall(function()
					instance:Destroy()
				end)
			end)
		end
	end

	local function disableBoostFpsLightingEffects()
		pcall(function()
			for _, effect in ipairs(Lighting:GetDescendants()) do
				if
					effect:IsA("BlurEffect")
					or effect:IsA("SunRaysEffect")
					or effect:IsA("ColorCorrectionEffect")
					or effect:IsA("BloomEffect")
					or effect:IsA("DepthOfFieldEffect")
				then
					effect.Enabled = false
				elseif effect:IsA("Atmosphere") then
					effect:Destroy()
				end
			end
		end)
	end

	local function boostFps()
		disconnectBoostFpsConnections()

		local terrain = workspace:FindFirstChildOfClass("Terrain")
		if terrain then
			pcall(function()
				terrain.WaterWaveSize = 0
				terrain.WaterWaveSpeed = 0
				terrain.WaterReflectance = 0
				terrain.WaterTransparency = 0
			end)
		end

		pcall(function()
			Lighting.GlobalShadows = false
			Lighting.FogEnd = 9e9
		end)
		pcall(function()
			settings().Rendering.FrameRateManager = 0
		end)
		pcall(function()
			settings().Rendering.QualityLevel = 1
		end)
		pcall(function()
			settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
		end)

		for _, instance in ipairs(game:GetDescendants()) do
			optimizeInstanceForBoostFps(instance)
		end
		disableBoostFpsLightingEffects()

		local workspaceConnection = workspace.DescendantAdded:Connect(optimizeInstanceForBoostFps)
		local lightingConnection = Lighting.DescendantAdded:Connect(function(instance)
			optimizeInstanceForBoostFps(instance)
			disableBoostFpsLightingEffects()
		end)
		table.insert(fpsBoostState.connections, workspaceConnection)
		table.insert(fpsBoostState.connections, lightingConnection)
		addGuiConnection(workspaceConnection)
		addGuiConnection(lightingConnection)

		notify("Settings", "Boost FPS applied")
	end

