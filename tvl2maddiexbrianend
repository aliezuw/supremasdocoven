				local function untrackPlayer(targetPlayer)
					espState.trackedPlayers[targetPlayer] = nil
				end

				local function setupCharacterESP(targetPlayer)
					if espState.connections[targetPlayer] then
						for _, conn in pairs(espState.connections[targetPlayer]) do
							if conn then
								conn:Disconnect()
							end
						end
					end
					espState.connections[targetPlayer] = {}

					local function handleCharacter(char)
						local hrp = char:FindFirstChild("HumanoidRootPart")
						if hrp then
							local specieType = char:GetAttribute("SpecieType")
							if specieType then
								specieTypesCache[targetPlayer.UserId] = specieType
							end
						end
					end

					if targetPlayer.Character then
						handleCharacter(targetPlayer.Character)
					end

					local charAddedConn = targetPlayer.CharacterAdded:Connect(handleCharacter)
					table.insert(espState.connections[targetPlayer], charAddedConn)
					table.insert(getgenv().tvlESP, charAddedConn)
				end

				local function setUpCached(targetPlayer)
					task.spawn(function()
						if not espState.connections[targetPlayer] then
							espState.connections[targetPlayer] = {}
						end

						local characterNameChanged
						local specieChanged
						local headTransparencyChanged
						local headAddedConnection
						local headRemovedConnection

						local function disconnectHeadVisibilityConnections()
							if headTransparencyChanged then
								headTransparencyChanged:Disconnect()
								headTransparencyChanged = nil
							end
							if headAddedConnection then
								headAddedConnection:Disconnect()
								headAddedConnection = nil
							end
							if headRemovedConnection then
								headRemovedConnection:Disconnect()
								headRemovedConnection = nil
							end
						end

						local function handleCharacterAttributes(char)
							if specieChanged then
								specieChanged:Disconnect()
							end

							local specieType = char:GetAttribute("SpecieType")
							if specieType then
								specieTypesCache[targetPlayer.UserId] = specieType
							end

							specieChanged = char:GetAttributeChangedSignal("SpecieType"):Connect(function()
								local newSpecieType = char:GetAttribute("SpecieType")
								if newSpecieType then
									specieTypesCache[targetPlayer.UserId] = newSpecieType
								end
							end)
						end

						local function attachHeadVisibility(char)
							disconnectHeadVisibilityConnections()
							espView.setVisibilityDisplayValue(targetPlayer, nil)

							if not char then
								return
							end

							local function bindHead(head)
								if not head or not head:IsA("BasePart") or head.Name ~= "Head" then
									return
								end

								if headTransparencyChanged then
									headTransparencyChanged:Disconnect()
									headTransparencyChanged = nil
								end

								espView.setVisibilityDisplayValue(targetPlayer, head)
								headTransparencyChanged = head:GetPropertyChangedSignal("Transparency")
									:Connect(function()
										espView.setVisibilityDisplayValue(targetPlayer, head)
									end)
								table.insert(espState.connections[targetPlayer], headTransparencyChanged)
							end

							bindHead(char:FindFirstChild("Head"))

							headAddedConnection = char.ChildAdded:Connect(function(child)
								if child.Name == "Head" and child:IsA("BasePart") then
									bindHead(child)
								end
							end)
							table.insert(espState.connections[targetPlayer], headAddedConnection)

							headRemovedConnection = char.ChildRemoved:Connect(function(child)
								if child.Name == "Head" then
									if headTransparencyChanged then
										headTransparencyChanged:Disconnect()
										headTransparencyChanged = nil
									end
									espView.setVisibilityDisplayValue(targetPlayer, nil)
								end
							end)
							table.insert(espState.connections[targetPlayer], headRemovedConnection)
						end

						if targetPlayer.Character then
							handleCharacterAttributes(targetPlayer.Character)
							attachHeadVisibility(targetPlayer.Character)
						end

						local charAddedForAttr = targetPlayer.CharacterAdded:Connect(handleCharacterAttributes)
						table.insert(espState.connections[targetPlayer], charAddedForAttr)
						table.insert(getgenv().tvlESP, charAddedForAttr)

						local charAddedForVisibility = targetPlayer.CharacterAdded:Connect(attachHeadVisibility)
						table.insert(espState.connections[targetPlayer], charAddedForVisibility)
						table.insert(getgenv().tvlESP, charAddedForVisibility)

						if characterNameChanged then
							characterNameChanged:Disconnect()
						end

						local charName = targetPlayer:GetAttribute("CharacterName")
						if charName then
							characterNamesCache[targetPlayer.UserId] = charName
						end

						characterNameChanged = targetPlayer
							:GetAttributeChangedSignal("CharacterName")
							:Connect(function()
								local newCharName = targetPlayer:GetAttribute("CharacterName")
								if newCharName then
									characterNamesCache[targetPlayer.UserId] = newCharName
								end
							end)

						table.insert(espState.connections[targetPlayer], characterNameChanged)
						table.insert(getgenv().tvlESP, characterNameChanged)

						local removedConn = targetPlayer.AncestryChanged:Connect(function(_, parent)
							if not parent then
								characterNamesCache[targetPlayer.UserId] = nil
								specieTypesCache[targetPlayer.UserId] = nil
								friendsCache[targetPlayer.UserId] = nil
								espState.visibilityDisplayCache[targetPlayer.UserId] = nil

								if espState.connections[targetPlayer] then
									for _, conn in pairs(espState.connections[targetPlayer]) do
										if conn then
											conn:Disconnect()
										end
									end
									espState.connections[targetPlayer] = nil
								end

								if specieChanged then
									specieChanged:Disconnect()
								end
								disconnectHeadVisibilityConnections()
							end
						end)

						table.insert(espState.connections[targetPlayer], removedConn)
						table.insert(getgenv().tvlESP, removedConn)
					end)
