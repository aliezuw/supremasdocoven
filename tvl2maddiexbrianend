				end
			end
			outspammerUi.offenseDropdown:Set(currentOffenseSelection)
		end

		local function setSelectedAbilities(options)
			outspammerSelections.selectedAbilityByKey = {}

			if typeof(options) == "table" then
				for _, option in ipairs(options) do
					if typeof(option) == "string" then
						local key = outspammerCatalog.abilityKeyByDisplay[option] or option
						if outspammerStorage.validAbilityKeySet[key] then
							outspammerSelections.selectedAbilityByKey[key] = true
						end
					end
				end
			elseif typeof(options) == "string" then
				local key = outspammerCatalog.abilityKeyByDisplay[options] or options
				if outspammerStorage.validAbilityKeySet[key] then
					outspammerSelections.selectedAbilityByKey[key] = true
				end
			end

			for key in pairs(outspammerSelections.selectedOffenseByKey) do
				if not outspammerSelections.selectedAbilityByKey[key] then
					outspammerSelections.selectedOffenseByKey[key] = nil
				end
			end

			rebuildAbilityMaps()
			refreshOffenseDropdown()
			saveOutspammerSelections()
		end

		local loadedAbilitySelections, loadedOffenseSelections = readOutspammerSelections()
		for _, key in ipairs(outspammerCatalog.allAbilityKeys) do
			outspammerSelections.selectedAbilityByKey[key] = loadedAbilitySelections[key] == true
			outspammerSelections.selectedOffenseByKey[key] = loadedOffenseSelections[key] == true
		end
		for key in pairs(outspammerSelections.selectedOffenseByKey) do
			if not outspammerSelections.selectedAbilityByKey[key] then
				outspammerSelections.selectedOffenseByKey[key] = nil
			end
		end
		rebuildAbilityMaps()

		local function emulateHoldAndUnhold(abilityObject)
			if typeof(abilityObject) ~= "table" then
				return
			end

			if type(abilityObject.activated) ~= "function" then
				return
			end

			if not AbilityClient.getState() then
				AbilitySelected:FireServer(abilityObject._name)
				return
			end

			local abilityData = AbilityData[abilityObject._name]
			if abilityData and not PlayerStatsClient.hasAtLeast(abilityData.statType, abilityData.statCost) then
				if ClientDebounce.set("missingStat", 3) then
					FusionStates.SetNotification:Fire("Not enough " .. tostring(abilityData.statType))
				end
				return
			end

			if abilityData and abilityData.statType == StatType.Magic then
				if localPlayer:GetAttribute("MagicShackles") then
					if ClientDebounce.set("MagicShacklesNotification", 3) then
						FusionStates.SetNotification:Fire("You can't use magic while shackled")
					end
					return
				end
				if localPlayer:GetAttribute("MAGIC_LOCK") then
					if ClientDebounce.set("MagicShacklesNotification", 3) then
						FusionStates.SetNotification:Fire("You can't use magic right now!")
					end
					return
				end
			end

			--if abilityObject._isHolding then
			--	return
			--end

			local requiresTarget = (abilityData and abilityData.targetType) or abilityObject._targetType
			if requiresTarget and not abilityObject._targetSystem then
				return
			end

			for i = 1, 50 do
				task.spawn(function()
					abilityObject._isHolding = true
					abilityObject:activated()

					task.defer(function()
						abilityObject._isHolding = false
						abilityObject:deactivate()
					end)
				end)
			end
		end

		local function resolveTargetPlayer(targetInfo)
			if typeof(targetInfo) ~= "Instance" then
				return nil
			end

			if targetInfo:IsA("Player") then
				return targetInfo
			end

			if targetInfo.Parent and targetInfo.Parent:IsA("Player") then
				return targetInfo.Parent
			end

			local model = targetInfo:IsA("Model") and targetInfo or targetInfo:FindFirstAncestorOfClass("Model")
			if not model then
				return nil
			end

			return Players:GetPlayerFromCharacter(model)
		end

		local function isInvisibleTarget(player)
			local character = player and player.Character
			if not character then
				return false
			end

			local head = character:FindFirstChild("Head")
			return head and head:IsA("BasePart") and head.Transparency ~= 0 or false
		end

		local function getCurrentOutspammerAbility()
			if not outspammerFlags.enabled then
				return nil
			end

			local ability = AbilityHandler.activeAbility
			if
				not ability
				or ability._name == AbilityName.Invisique
				or ability._holding
				or not outspammerSelections.selectedAbilities[ability._name]
			then
				return nil
			end

			local targetPlayer
			if
				(outspammerFlags.protectFriendsEnabled or outspammerFlags.excludeInvisibleTargetsEnabled)
				and ability._targetSystem
				and ability._targetSystem.GetTargetInfo
			then
				local succ, targetInfo = pcall(function()
					return ability._targetSystem:GetTargetInfo()
				end)
				if succ then
					targetPlayer = resolveTargetPlayer(targetInfo)
				end
			end

			if outspammerFlags.protectFriendsEnabled then
				local isOffenseAbility = outspammerSelections.offenseAbilities[ability._name] == true

				local isFriendTarget = targetPlayer and checkIsFriend(targetPlayer) or false

				-- Only block offensive abilities when the current target is a friend.
				-- Non-offensive abilities are allowed on anyone.
				if isOffenseAbility and isFriendTarget then
					return nil
				end
			end

			if outspammerFlags.excludeInvisibleTargetsEnabled and targetPlayer and isInvisibleTarget(targetPlayer) then
				return nil
			end

			return ability
		end

		local outspammerConnection = RunService.Heartbeat:Connect(function()
			local ability = getCurrentOutspammerAbility()
			if not ability then
				return
			end

			emulateHoldAndUnhold(ability)
