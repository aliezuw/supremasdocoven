		do
			-- main functionality
			for name, conn in pairs(getgenv().autoSteal or {}) do
				--	print(name)
				conn:Disconnect()
				getgenv().autoSteal[name] = nil
			end
			getgenv().autoSteal = {}
			getgenv().autoSteal.activeConnection = nil

			if getgenv().autoStealConnections then
				for _, conn in pairs(getgenv().autoStealConnections) do
					conn:Disconnect()
				end
				getgenv().autoStealConnections = nil
			end

			getgenv().autoStealConnections = {}
			local activeConnection

			local function stopAutoStealProcesses(showNotification)
				if activeConnection then
					activeConnection:Disconnect()
					activeConnection = nil
				end

				if typeof(getgenv().autoSteal) ~= "table" then
					getgenv().autoSteal = {}
				end

				if getgenv().autoSteal.activeConnection then
					getgenv().autoSteal.activeConnection:Disconnect()
					getgenv().autoSteal.activeConnection = nil
				end

				for name, conn in pairs(getgenv().autoSteal) do
					if typeof(conn) == "RBXScriptConnection" then
						conn:Disconnect()
					end
					getgenv().autoSteal[name] = nil
				end
				getgenv().autoSteal.activeConnection = nil

				if typeof(getgenv().autoStealConnections) ~= "table" then
					getgenv().autoStealConnections = {}
				end

				for index, conn in pairs(getgenv().autoStealConnections) do
					if typeof(conn) == "RBXScriptConnection" then
						conn:Disconnect()
					end
					getgenv().autoStealConnections[index] = nil
				end

				if showNotification then
					notify("Autosteal", "Stopped all auto steal processes")
				end
			end

			local function autoSteal()
				if not isCurrentSessionActive() then
					Rayfield:Destroy()
					return
				end

				local CharacterList =
					ReplicatedStorage.Remotes.GameServices.ToServer.RequestCharacterList:InvokeServer()
				local startScreen = playerGui:WaitForChild("StartScreen")
				local mainHolder = startScreen:WaitForChild("MainHolder")

				if mainHolder.Visible then
				else
					notify("Autosteal", "You must be on the character selection screen to use auto steal")
					return
				end

				local takenLabel = mainHolder.CharacterInfoMiddle.TakenAnnouncement

				local function extractName(text)
					local displayName = text:match("^(.-) is already taken")
					for realName, data in pairs(ShowCharacters) do
						if data.DisplayName == displayName then
							return realName
						end
					end
				end

				local spawnFunction
				local confirmFunction
				for _, value in next, getgc(true) do
					if typeof(value) == "function" and islclosure(value) then
						local info = debug.getinfo(value)
						if not spawnFunction and info.name == "spawnButtonActivated" then
							spawnFunction = value
						elseif
							not confirmFunction
							and info.name == "confirmPressed"
							and info.source:find("ConfirmPrompt")
						then
							confirmFunction = value
						end
						if spawnFunction and confirmFunction then
							break
						end
					end
				end

				local function spawn()
					task.spawn(spawnFunction)
					task.spawn(confirmFunction)
				end

				if not takenLabel.Text:find("is already taken") then
					notify("Autosteal", "Character is not taken. Spawning...")
					spawn()
					return
				end

				local characterName = extractName(takenLabel.Text)
				if not characterName or not CharacterList[characterName] then
					notify("Autosteal", "Character is not taken. Spawning...")
					spawn()
					return
				end

				local itemFrame = mainHolder.SelectCharacterFrame.LeftArea.MiddleArea.BottomArea.ItemFrame
				local takenLabel = mainHolder.CharacterInfoMiddle.TakenAnnouncement
				for _, descendant in pairs(itemFrame:GetDescendants()) do
					if descendant:IsA("ViewportFrame") and descendant.Name == characterName then
						selectedShadow = descendant
						break
					end
				end

				notify("Autosteal", "Auto steal started for " .. characterName)

				if getgenv().autoSteal.activeConnection then
					getgenv().autoSteal.activeConnection:Disconnect()
					getgenv().autoSteal.activeConnection = nil
				end

				getgenv().autoSteal.activeConnection = CharacterListUpdated.OnClientEvent:Connect(function(characters)
					if not characters[characterName] then
						local startTime = tick()
						selectedShadow:GetPropertyChangedSignal("ImageColor3"):Wait()
						task.spawn(spawnFunction)
						task.spawn(confirmFunction)
						local duration = tick() - startTime
						notify("Autosteal", "Took " .. tostring(duration) .. " seconds to deploy")
						if getgenv().autoSteal.activeConnection then
							getgenv().autoSteal.activeConnection:Disconnect()
							getgenv().autoSteal.activeConnection = nil
						end
					end
				end)

				localPlayer:GetAttributeChangedSignal("CharacterName"):Once(function()
					if getgenv().autoSteal.activeConnection then
						getgenv().autoSteal.activeConnection:Disconnect()
						getgenv().autoSteal.activeConnection = nil
					end
				end)
				takenLabel:GetPropertyChangedSignal("Text"):Once(function()
					if getgenv().autoSteal.activeConnection then
						getgenv().autoSteal.activeConnection:Disconnect()
						getgenv().autoSteal.activeConnection = nil
					end
				end)
			end

			tvlGui.autoStealFunction = autoSteal

			-- ui element
			local autoSteal = main:CreateKeybind({
				Name = "Auto Steal",
				CurrentKeybind = "J",
				HoldToInteract = false,
				Flag = "autoStealKey",
				Callback = autoSteal,
			})
			addUiElement("buttons", autoSteal)

			local stopAutoStealButton = main:CreateButton({
				Name = "Stop Auto Steal",
				Callback = function()
					stopAutoStealProcesses(true)
				end,
			})
			addUiElement("buttons", stopAutoStealButton)
		end

