			local function isPlayerInLobby(player)
				local character = player and player.Character
				if not character then
					return false
				end

				local hrp = character:FindFirstChild("HumanoidRootPart")
				return hrp ~= nil and hrp.Position.Y < -300
			end

			local function getPlayerInfo(player)
				if player == localPlayer then
					return nil
				end

				local charName = characterNamesCache[player.UserId] or "Unknown"
				local specieType = specieTypesCache[player.UserId] or "Unknown"

				if player.Character then
					specieType = specieType or "Unknown"
				end

				local displayName = (player.DisplayName ~= player.Name)
						and (player.DisplayName .. " (@" .. player.Name .. ")")
					or player.Name

				local isFriend = checkIsFriend(player)
				local inLobby = isPlayerInLobby(player)

				return {
					playerName = player.Name,
					displayName = displayName,
					specieType = specieType,
					characterName = charName,
					isFriend = isFriend,
					inLobby = inLobby,
				}
			end

			local function removePlayerLabel(userId)
				local label = playerLabels[userId]
				if not label then
					return
				end

				removeUiValue(label)

				playerLabels[userId] = nil
			end

			local function setEmptyState(visible)
				if visible then
					if not emptyStateLabel then
						emptyStateLabel = playerList:CreateLabel("No other players online")
					else
						emptyStateLabel:Set("No other players online")
					end
				elseif emptyStateLabel then
					removeUiValue(emptyStateLabel)
					emptyStateLabel = nil
				end
			end

			local function formatLabelText(info)
				return string.format(
					"%s | %s | %s%s%s",
					info.displayName,
					info.characterName,
					info.specieType,
					info.inLobby and " | In Lobby" or "",
					info.isFriend and " | Friend" or ""
				)
			end

			local function updatePlayerList()
				local activeUserIds = {}
				local hasPlayers = false

				for _, player in ipairs(Players:GetPlayers()) do
					if player ~= localPlayer then
						local info = getPlayerInfo(player)
						if info then
							hasPlayers = true
							activeUserIds[player.UserId] = true

							local labelText = formatLabelText(info)
							local existingLabel = playerLabels[player.UserId]
							if existingLabel then
								existingLabel:Set(labelText)
							else
								playerLabels[player.UserId] = playerList:CreateLabel(labelText)
							end
						end
					end
				end

				for userId in pairs(playerLabels) do
					if not activeUserIds[userId] then
						removePlayerLabel(userId)
					end
				end

				setEmptyState(not hasPlayers)
			end

			-- Initial player list
			updatePlayerList()

			local lastUpdate = tick()
			local updateCooldown = 2 -- seconds

			local function safeRefresh()
				local currentTime = tick()
				if currentTime - lastUpdate < updateCooldown then
					return
				end
				lastUpdate = currentTime
				updatePlayerList()
			end

			local conn1 = Players.PlayerAdded:Connect(function()
				task.wait(1)
				safeRefresh()
			end)
			addGuiConnection(conn1)

			local conn2 = Players.PlayerRemoving:Connect(function()
				safeRefresh()
			end)
			addGuiConnection(conn2)

			local conn3 = CharacterListUpdated.OnClientEvent:Connect(function()
				task.wait(0.5)
				safeRefresh()
			end)
			addGuiConnection(conn3)

			task.spawn(function()
				while isCurrentSessionActive() do
					task.wait(10)
					safeRefresh()
				end
			end)
		end
	end
end
