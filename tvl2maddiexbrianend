					local tools, seen = {}, {}
					for _, tool in ipairs(bp:GetChildren()) do
						local mapped = toolNames[tool.Name]
						if mapped and not seen[mapped] then
							seen[mapped] = true
							table.insert(tools, mapped)
						end
					end
					return #tools > 0 and table.concat(tools, ", ") or nil
				end

