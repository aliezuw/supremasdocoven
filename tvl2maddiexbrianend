local function announce(title, content, duration)
	if not announcementsEnabled then
		return
	end
	local payload = {
		Title = title,
		Content = content,
		Duration = duration or 5,
		Image = 11028823406,
	}
	if Rayfield.Announce then
		return Rayfield:Announce(payload)
	end
	return Rayfield:Notify(payload)
end

