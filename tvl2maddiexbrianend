				local function disconnectTrackedConnection(connection)
					if connection then
						connection:Disconnect()
					end
				end

				local function setAutoIctusSpecieTracking(character)
					disconnectTrackedConnection(ictus.state.specieChangedConnection)
					ictus.state.specieChangedConnection = nil
					ictus.state.specie = nil

					if not character then
						return
					end

					ictus.state.specie = character:GetAttribute("SpecieType")
					ictus.state.specieChangedConnection = character
						:GetAttributeChangedSignal("SpecieType")
						:Connect(function()
							ictus.state.specie = character:GetAttribute("SpecieType")
						end)
					addGuiConnection(ictus.state.specieChangedConnection)
				end

				local function getLikelyIctusTarget()
					local character = localPlayer.Character
					if not character or not character.PrimaryPart then
						return nil
					end

					local entitiesFolder = workspace:FindFirstChild("Entities")
					if not entitiesFolder then
						return nil
					end

					local characterPos = character.PrimaryPart.Position

					for _, entity in ipairs(entitiesFolder:GetChildren()) do
						if entity ~= character and entity.PrimaryPart then
							local magnitude = (entity.PrimaryPart.Position - characterPos).Magnitude
							if magnitude <= ictus.config.range then
								local humanoid = entity:FindFirstChildWhichIsA("Humanoid")
								if humanoid then
									for _, animationTrack in ipairs(humanoid:GetPlayingAnimationTracks()) do
										if ictus.threatAnimations[animationTrack.Animation.AnimationId] then
											return entity
										end
									end
								end
							end
						end
					end

					return nil
				end

				local function disableAutoIctus()
					local state = ictus.state
					state.enabled = false
					disconnectTrackedConnection(state.loopConnection)
					disconnectTrackedConnection(state.characterAddedConnection)
					disconnectTrackedConnection(state.specieChangedConnection)
					state.loopConnection = nil
					state.characterAddedConnection = nil
					state.specieChangedConnection = nil
					state.specie = nil
				end

				local function setAutoIctusEnabled(enabled)
					local state = ictus.state
					if not enabled then
						disableAutoIctus()
						notify("Auto Ictus", "Disabled Auto Ictus")
						return
					end

					if state.enabled then
						return
					end

					state.enabled = true
					state.lastEquipAttempt = 0
					setAutoIctusSpecieTracking(localPlayer.Character)

					state.characterAddedConnection = localPlayer.CharacterAdded:Connect(setAutoIctusSpecieTracking)
					addGuiConnection(state.characterAddedConnection)

					state.loopConnection = RunService.Heartbeat:Connect(function()
						if not state.enabled then
							return
						end

						local startScreen = playerGui:FindFirstChild("StartScreen")
						local mainHolder = startScreen and startScreen:FindFirstChild("MainHolder")
						if mainHolder and mainHolder.Visible then
							return
						end

						if not ictus.allowedSpecies[state.specie] then
							return
						end

						local character = localPlayer.Character
						local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
						if not character or not humanoid then
							return
						end

						local state = AbilityClient.getState()
						if state or character:GetAttribute("ragdoll") or humanoid.WalkSpeed ~= 0 then
							return
						end

						local target = getLikelyIctusTarget()
						if not target then
							return
						end

						if not AbilityClient.doesOwn("Ictus") then
							return
						end

						if tick() - state.lastEquipAttempt <= ictus.config.equipCooldown then
							return
						end

						state.lastEquipAttempt = tick()

						if AbilityClient.getEquippedAbility() == "Ictus" then
							AbilityClient.setAbility()
							AbilityClient.setAbility("Ictus")
							AbilityClient.setAbility()
							AbilityClient.setAbility("Ictus")
						else
							AbilityClient.setAbility("Ictus")
							AbilityClient.setAbility()
							AbilityClient.setAbility("Ictus")
						end
					end)
					addGuiConnection(state.loopConnection)

					notify("Auto Ictus", "Enabled Auto Ictus")
				end

				local autoIctusToggle = main:CreateToggle({
					Name = "Auto Ictus",
					CurrentValue = false,
					Flag = "autoIctusToggle",
					Callback = setAutoIctusEnabled,
